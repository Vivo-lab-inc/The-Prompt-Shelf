---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Prompt Shelf', description = 'Curated collection of AI coding rules and creative prompts.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="border-b border-[--color-border] sticky top-0 z-50 bg-[--color-bg]/85 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <!-- Shelf icon -->
          <div class="relative w-7 h-7">
            <div class="absolute inset-0 rounded-md bg-gradient-to-br from-[--color-accent] to-[--color-pink] opacity-90"></div>
            <div class="absolute inset-[3px] rounded-[3px] bg-[--color-bg] flex items-center justify-center">
              <div class="flex gap-[2px]">
                <div class="w-[3px] h-3 rounded-[1px] bg-[--color-accent]"></div>
                <div class="w-[3px] h-3.5 rounded-[1px] bg-[--color-pink]"></div>
                <div class="w-[3px] h-2.5 rounded-[1px] bg-[--color-accent]"></div>
              </div>
            </div>
          </div>
          <span class="font-bold text-[15px] tracking-tight group-hover:text-[--color-accent] transition-colors">
            The Prompt Shelf
          </span>
        </a>
        <div class="flex items-center gap-5 text-[13px] text-[--color-text-muted]">
          <a href="/rules" class="hover:text-[--color-text] transition-colors">Browse</a>
          <a href="/about" class="hover:text-[--color-text] transition-colors">About</a>
          <a href="https://x.com/yuto_lab_note" target="_blank" class="hover:text-[--color-text] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com" target="_blank" class="hover:text-[--color-text] transition-colors">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-[--color-border] py-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between text-[12px] text-[--color-text-muted]">
        <p>The Prompt Shelf</p>
        <p>Built by <a href="https://x.com/yuto_lab_note" target="_blank" class="text-[--color-accent] hover:underline">@yuto_lab_note</a></p>
      </div>
    </footer>
  </body>
</html>
