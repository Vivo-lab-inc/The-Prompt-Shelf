---
import Layout from '../layouts/Layout.astro';
import RuleCard from '../components/RuleCard';
import rules from '../data/rules.json';

const featured = rules.sort((a, b) => b.stars - a.stars);
const filters = ['All', 'Cursor', 'Claude Code', 'Agents.md', 'Image Prompts'];
---

<Layout title="The-Prompt-Shelf — Curated AI Rules & Prompts" description="A curated collection of system prompts, agent instructions, and context rules for modern AI coding assistants.">

  <!-- Background layers -->
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="bg-grid absolute inset-0"></div>
    <div class="bg-noise absolute inset-0"></div>
    <div class="top-ambient"></div>
  </div>

  <!-- Hero -->
  <header class="pt-24 pb-16 px-6 max-w-[1400px] mx-auto w-full relative z-10">
    <div class="flex flex-col items-center text-center space-y-6">
      <h1 class="font-display text-4xl md:text-[44px] font-medium tracking-tight text-text-main animate-in">
        The-Prompt-Shelf
      </h1>
      <p class="text-text-muted text-[15px] max-w-xl mx-auto leading-relaxed animate-in animate-in-delay-1" id="hero-desc"
        data-en="A curated collection of system prompts, agent instructions, and context rules. Optimized for modern AI coding assistants."
        data-ja="AIコーディングアシスタントのための、システムプロンプト・エージェント指示・コンテキストルールの厳選コレクション。"
      >
        AIコーディングアシスタントのための、システムプロンプト・エージェント指示・コンテキストルールの厳選コレクション。
      </p>

      <!-- Search -->
      <div class="w-full max-w-2xl pt-6 animate-in animate-in-delay-2">
        <div class="relative">
          <svg class="absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-text-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="hero-search"
            placeholder="Search rules, frameworks, languages..."
            class="w-full pl-14 pr-14 py-4 bg-gradient-to-r from-[#181818] to-[#141414] border border-border-subtle rounded-full text-text-main placeholder:text-[#555] outline-none focus:border-border-strong text-[15px] transition-colors"
          />
          <kbd class="absolute right-6 top-1/2 -translate-y-1/2 text-[11px] text-text-faint/50 font-mono">/</kbd>
        </div>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap items-center justify-center gap-2 pt-4 animate-in animate-in-delay-3">
        {filters.map((filter, i) => (
          <a
            href={i === 0 ? '/rules' : `/rules?tool=${filter.toLowerCase().replace(' ', '-').replace('.', '')}`}
            class:list={[
              "px-4 py-1.5 rounded-full text-[13px] tracking-wide transition-all duration-200 border",
              i === 0
                ? "bg-white/[0.08] text-text-main border-white/10"
                : "bg-transparent text-text-muted border-transparent hover:text-text-main hover:bg-white/[0.03]"
            ]}
          >
            {filter}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Coding Rules Section -->
  <section class="px-6 pb-24 max-w-[1400px] mx-auto w-full relative z-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-lg font-medium tracking-tight text-text-main">Coding Rules</h2>
        <p class="text-[13px] text-text-faint mt-1 tracking-wide">CLAUDE.md, .cursorrules, AGENTS.md</p>
      </div>
      <a href="/rules" class="text-[13px] text-text-faint hover:text-text-muted transition-colors tracking-wide">
        View all
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-14">
      {featured.map(rule => (
        <RuleCard client:load rule={rule} />
      ))}
    </div>
  </section>

  <!-- Image Prompts Section (Coming Soon) -->
  <section class="px-6 pb-32 max-w-[1400px] mx-auto w-full relative z-10">
    <div class="border-t border-border-subtle pt-16">
      <div class="flex items-center gap-3 mb-3">
        <h2 class="text-lg font-medium tracking-tight text-text-main">Image Prompts</h2>
        <span class="px-2 py-0.5 text-[10px] tracking-widest uppercase text-text-faint border border-border-subtle rounded-full">Soon</span>
      </div>
      <p class="text-[13px] text-text-faint tracking-wide mb-10">
        Midjourney, DALL-E, Stable Diffusion, Flux — curated prompts with generated results.
      </p>

      <!-- Placeholder cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-6">
        {[1, 2, 3, 4].map(() => (
          <div class="bg-surface border border-border-subtle rounded-[3px] overflow-hidden opacity-40">
            <div class="aspect-[4/3] bg-gradient-to-br from-white/[0.02] to-transparent"></div>
            <div class="p-5 space-y-3">
              <div class="h-3 w-3/4 bg-white/[0.04] rounded-full"></div>
              <div class="h-2 w-1/2 bg-white/[0.03] rounded-full"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('hero-search');
    if (searchInput) {
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const query = (e.target as HTMLInputElement).value;
          if (query.trim()) window.location.href = `/rules?q=${encodeURIComponent(query.trim())}`;
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement !== searchInput) {
          e.preventDefault();
          searchInput.focus();
        }
      });
    }
  </script>
</Layout>
