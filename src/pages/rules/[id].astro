---
import Layout from '../../layouts/Layout.astro';
import RuleCard from '../../components/RuleCard';
import rules from '../../data/rules.json';

export function getStaticPaths() {
  return rules.map(rule => ({
    params: { id: rule.id },
    props: { rule },
  }));
}

const { rule } = Astro.props;

const toolConfig: Record<string, { label: string; class: string; gradient: string }> = {
  'cursor': { label: '.cursorrules', class: 'badge-cursor', gradient: 'from-blue-500/30 to-blue-500/5' },
  'claude-code': { label: 'CLAUDE.md', class: 'badge-claude', gradient: 'from-orange-500/30 to-orange-500/5' },
  'agents-md': { label: 'AGENTS.md', class: 'badge-agents', gradient: 'from-green-500/30 to-green-500/5' },
};

const config = toolConfig[rule.tool] || toolConfig['agents-md'];

const related = rules
  .filter(r => r.id !== rule.id && (r.category === rule.category || r.language === rule.language))
  .sort((a, b) => b.stars - a.stars)
  .slice(0, 3);

const lineCount = rule.content.split('\n').length;
---

<Layout title={`${rule.title} - The Prompt Shelf`} description={rule.description}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-[13px] text-[--color-text-muted] mb-10">
      <a href="/" class="hover:text-[--color-text] transition-colors">Home</a>
      <span class="text-[--color-border]">/</span>
      <a href="/rules" class="hover:text-[--color-text] transition-colors">Rules</a>
      <span class="text-[--color-border]">/</span>
      <span class="text-[--color-text]">{rule.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10">
      <!-- Main content -->
      <div>
        <!-- Header -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-5">
            <span class={"px-3 py-1.5 text-[12px] font-semibold rounded-lg border uppercase tracking-wider " + config.class}>
              {config.label}
            </span>
            <span class="flex items-center gap-1.5 text-sm text-[--color-text-muted]">
              <svg class="w-4 h-4 fill-[--color-yellow]/40 text-[--color-yellow]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {rule.stars.toLocaleString()}
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">{rule.title}</h1>
          <p class="text-lg text-[--color-text-muted] leading-relaxed">{rule.description}</p>
        </div>

        <!-- Code block -->
        <div class="relative group">
          <!-- Shelf spine accent on the left -->
          <div class={"absolute left-0 top-0 bottom-0 w-1 rounded-l-xl bg-gradient-to-b " + config.gradient}></div>

          <div class="bg-[--color-surface] border border-[--color-border] rounded-xl overflow-hidden">
            <!-- File header -->
            <div class="flex items-center justify-between px-5 py-3 border-b border-[--color-border] bg-[--color-surface-alt]">
              <div class="flex items-center gap-2">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-[#ff5f57]/70"></div>
                  <div class="w-3 h-3 rounded-full bg-[#febc2e]/70"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28c840]/70"></div>
                </div>
                <span class="ml-3 text-[12px] text-[--color-text-muted] font-mono">{rule.format}</span>
                <span class="text-[11px] text-[--color-text-muted]/40 font-mono">{lineCount} lines</span>
              </div>
              <button
                id="copy-btn"
                class="flex items-center gap-2 px-3 py-1.5 text-[12px] rounded-lg bg-[--color-bg] border border-[--color-border] text-[--color-text-muted] hover:text-[--color-text] hover:border-[--color-accent]/30 transition-all"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
                <span id="copy-text">Copy</span>
              </button>
            </div>

            <!-- Code content -->
            <div class="p-5 overflow-x-auto">
              <pre class="!bg-transparent !border-0 !p-0 !m-0 !rounded-none"><code id="rule-content" class="text-[13px] leading-[1.75] !font-mono text-[--color-text]/85 whitespace-pre-wrap break-words">{rule.content}</code></pre>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Meta card -->
        <div class="rounded-xl bg-[--color-surface] border border-[--color-border] p-5">
          <h3 class="text-sm font-semibold mb-4 text-[--color-text-muted] uppercase tracking-wider">Details</h3>
          <dl class="space-y-3.5">
            <div class="flex justify-between">
              <dt class="text-[13px] text-[--color-text-muted]">Language</dt>
              <dd class="text-[13px] font-medium">{rule.language}</dd>
            </div>
            {rule.framework !== 'Any' && (
              <div class="flex justify-between">
                <dt class="text-[13px] text-[--color-text-muted]">Framework</dt>
                <dd class="text-[13px] font-medium">{rule.framework}</dd>
              </div>
            )}
            <div class="flex justify-between">
              <dt class="text-[13px] text-[--color-text-muted]">Category</dt>
              <dd class="text-[13px] font-medium capitalize">{rule.category.replace('-', ' ')}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[13px] text-[--color-text-muted]">Author</dt>
              <dd class="text-[13px] font-medium">{rule.author}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-[13px] text-[--color-text-muted]">Source</dt>
              <dd class="text-[13px] font-medium">{rule.source}</dd>
            </div>
          </dl>
        </div>

        <!-- Tags -->
        <div class="rounded-xl bg-[--color-surface] border border-[--color-border] p-5">
          <h3 class="text-sm font-semibold mb-3 text-[--color-text-muted] uppercase tracking-wider">Tags</h3>
          <div class="flex flex-wrap gap-2">
            {rule.tags.map((tag: string) => (
              <a
                href={`/rules?q=${tag}`}
                class="px-2.5 py-1 text-[11px] rounded-full bg-[--color-bg] border border-[--color-border] text-[--color-text-muted] hover:text-[--color-accent] hover:border-[--color-accent]/30 transition-all"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>

        <!-- Quick copy card -->
        <div class="rounded-xl bg-gradient-to-br from-[--color-accent]/[0.08] to-transparent border border-[--color-accent]/20 p-5">
          <h3 class="text-sm font-semibold mb-2">Use this rule</h3>
          <p class="text-[12px] text-[--color-text-muted] mb-3">
            Copy and paste into your project's <code class="text-[--color-accent]">{rule.format}</code> file.
          </p>
          <button
            id="copy-btn-sidebar"
            class="w-full py-2.5 rounded-lg bg-[--color-accent] hover:bg-[--color-accent-hover] text-white text-sm font-medium transition-colors"
          >
            Copy to Clipboard
          </button>
        </div>
      </aside>
    </div>

    <!-- Related Rules -->
    {related.length > 0 && (
      <section class="section-gradient mt-20 pt-12">
        <h2 class="text-xl font-bold mb-6">Related Rules</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {related.map(r => (
            <RuleCard client:visible rule={r} />
          ))}
        </div>
      </section>
    )}
  </div>

  <script define:vars={{ content: rule.content }}>
    function setupCopy(btnId) {
      const btn = document.getElementById(btnId);
      btn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(content);
          if (btnId === 'copy-btn') {
            const text = document.getElementById('copy-text');
            text.textContent = 'Copied!';
            setTimeout(() => { text.textContent = 'Copy'; }, 2000);
          } else {
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy to Clipboard'; }, 2000);
          }
        } catch {}
      });
    }
    setupCopy('copy-btn');
    setupCopy('copy-btn-sidebar');

    // Glow card mouse tracking
    document.addEventListener('mousemove', (e) => {
      const cards = document.querySelectorAll('.glow-card');
      cards.forEach((card) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
        card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
      });
    });
  </script>
</Layout>
