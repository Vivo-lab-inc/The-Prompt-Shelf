---
import Layout from '../../layouts/Layout.astro';
import RuleCard from '../../components/RuleCard';
import rules from '../../data/rules.json';

export function getStaticPaths() {
  return rules.map(rule => ({
    params: { id: rule.id },
    props: { rule },
  }));
}

const { rule } = Astro.props;
const lineCount = rule.content.split('\n').length;
const shareText = `${rule.title} - AI coding rules for ${rule.language}${rule.framework !== 'Any' ? ` + ${rule.framework}` : ''}`;
const shareUrl = `https://thepromptshelf.dev/rules/${rule.id}`;

const related = rules
  .filter(r => r.id !== rule.id && (r.category === rule.category || r.language === rule.language))
  .sort((a, b) => b.stars - a.stars)
  .slice(0, 4);

const toolCounts = {
  'claude-code': rules.filter(r => r.tool === 'claude-code').length,
  'cursor': rules.filter(r => r.tool === 'cursor').length,
  'agents-md': rules.filter(r => r.tool === 'agents-md').length,
};
const categoryCounts: Record<string, number> = {};
rules.forEach(r => { categoryCounts[r.category] = (categoryCounts[r.category] || 0) + 1; });

const categoryLabels: Record<string, string> = {
  'web-frontend': 'Frontend',
  'backend': 'Backend',
  'cli': 'CLI',
  'devops': 'DevOps',
  'security': 'Security',
};
---

<Layout title={`${rule.title} - The-Prompt-Shelf`} description={rule.description}>
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="bg-grid absolute inset-0"></div>
    <div class="bg-noise absolute inset-0"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 py-10 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-10">

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-8">
          <div>
            <h3 class="text-[11px] font-medium text-text-faint uppercase tracking-widest mb-4">Browse</h3>
            <nav class="space-y-1">
              <a href="/rules" class="sidebar-link flex items-center justify-between px-3 py-2 rounded-[3px] text-[13px] text-text-muted hover:text-text-main hover:bg-white/[0.03] transition-all">
                <span>All Rules</span>
                <span class="text-text-faint text-[11px]">{rules.length}</span>
              </a>
            </nav>
          </div>

          <div>
            <h3 class="text-[11px] font-medium text-text-faint uppercase tracking-widest mb-4">By Tool</h3>
            <nav class="space-y-1">
              <a href="/rules?tool=claude-code" class:list={["sidebar-link flex items-center justify-between px-3 py-2 rounded-[3px] text-[13px] transition-all", rule.tool === 'claude-code' ? 'text-text-main bg-white/[0.04] border border-border-subtle' : 'text-text-muted hover:text-text-main hover:bg-white/[0.03]']}>
                <span>CLAUDE.md</span>
                <span class="text-text-faint text-[11px]">{toolCounts['claude-code']}</span>
              </a>
              <a href="/rules?tool=cursor" class:list={["sidebar-link flex items-center justify-between px-3 py-2 rounded-[3px] text-[13px] transition-all", rule.tool === 'cursor' ? 'text-text-main bg-white/[0.04] border border-border-subtle' : 'text-text-muted hover:text-text-main hover:bg-white/[0.03]']}>
                <span>.cursorrules</span>
                <span class="text-text-faint text-[11px]">{toolCounts['cursor']}</span>
              </a>
              <a href="/rules?tool=agents-md" class:list={["sidebar-link flex items-center justify-between px-3 py-2 rounded-[3px] text-[13px] transition-all", rule.tool === 'agents-md' ? 'text-text-main bg-white/[0.04] border border-border-subtle' : 'text-text-muted hover:text-text-main hover:bg-white/[0.03]']}>
                <span>AGENTS.md</span>
                <span class="text-text-faint text-[11px]">{toolCounts['agents-md']}</span>
              </a>
            </nav>
          </div>

          <div>
            <h3 class="text-[11px] font-medium text-text-faint uppercase tracking-widest mb-4">By Category</h3>
            <nav class="space-y-1">
              {Object.entries(categoryCounts).map(([cat, count]) => (
                <a href={`/rules?category=${cat}`} class:list={["sidebar-link flex items-center justify-between px-3 py-2 rounded-[3px] text-[13px] transition-all", rule.category === cat ? 'text-text-main bg-white/[0.04] border border-border-subtle' : 'text-text-muted hover:text-text-main hover:bg-white/[0.03]']}>
                  <span>{categoryLabels[cat] || cat}</span>
                  <span class="text-text-faint text-[11px]">{count}</span>
                </a>
              ))}
            </nav>
          </div>

          <!-- Current rule info -->
          <div class="border-t border-border-subtle pt-6">
            <h3 class="text-[11px] font-medium text-text-faint uppercase tracking-widest mb-3">Details</h3>
            <dl class="space-y-2 text-[12px]">
              <div class="flex justify-between">
                <dt class="text-text-faint">Language</dt>
                <dd class="text-text-muted">{rule.language}</dd>
              </div>
              {rule.framework !== 'Any' && (
                <div class="flex justify-between">
                  <dt class="text-text-faint">Framework</dt>
                  <dd class="text-text-muted">{rule.framework}</dd>
                </div>
              )}
              <div class="flex justify-between">
                <dt class="text-text-faint">Author</dt>
                <dd class="text-text-muted">{rule.author}</dd>
              </div>
            </dl>

            <div class="flex flex-wrap gap-1.5 mt-4">
              {rule.tags.map((tag: string) => (
                <a href={`/rules?q=${tag}`} class="text-[10px] px-2 py-[2px] rounded-full border border-border-subtle text-text-faint hover:text-text-muted transition-all">
                  {tag}
                </a>
              ))}
            </div>

            {rule.sourceUrl && (
              <div class="mt-4">
                <a href={rule.sourceUrl} target="_blank" rel="noopener" class="text-[11px] text-text-faint hover:text-text-muted transition-colors flex items-center gap-1.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Source
                </a>
              </div>
            )}

            <button
              id="copy-btn-sidebar"
              class="w-full mt-5 py-2.5 bg-white/[0.06] hover:bg-white/[0.1] border border-white/[0.08] rounded-[3px] text-[12px] text-text-main font-medium transition-colors tracking-wide"
            >
              Copy to Clipboard
            </button>

            <a
              href={`https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`}
              target="_blank"
              rel="noopener"
              class="w-full mt-2 py-2.5 bg-transparent hover:bg-white/[0.04] border border-border-subtle rounded-[3px] text-[12px] text-text-faint hover:text-text-muted font-medium transition-colors tracking-wide flex items-center justify-center gap-2"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Share on X
            </a>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <div>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-[13px] text-text-faint mb-10 tracking-wide">
          <a href="/" class="hover:text-text-muted transition-colors">Home</a>
          <span>/</span>
          <a href="/rules" class="hover:text-text-muted transition-colors">Rules</a>
          <span>/</span>
          <span class="text-text-muted" data-en={rule.title} data-ja={rule.title_ja || rule.title}>{rule.title_ja || rule.title}</span>
        </nav>

        <!-- Header -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-2.5 py-1 text-[10px] font-medium tracking-wider uppercase bg-white/[0.06] border border-white/[0.08] rounded-full text-text-main">
              {rule.format}
            </span>
            <span class="text-[12px] text-text-faint flex items-center gap-1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="opacity-50"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {rule.stars}
            </span>
          </div>

          <h1 id="rule-title" class="font-display text-3xl font-medium tracking-tight text-text-main mb-3"
            data-en={rule.title} data-ja={rule.title_ja || rule.title}>{rule.title_ja || rule.title}</h1>
          <p id="rule-desc" class="text-text-muted text-[15px] leading-relaxed"
            data-en={rule.description} data-ja={rule.description_ja || rule.description}>{rule.description_ja || rule.description}</p>
        </div>

        <!-- Code block -->
        <div class="relative">
          <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-spine rounded-l-sm"></div>

          <div class="bg-surface border border-border-subtle rounded-[3px] overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3 border-b border-border-subtle">
              <div class="flex items-center gap-3">
                <span class="text-[12px] text-text-faint font-mono">{rule.format}</span>
                <span class="text-[11px] text-text-faint/50">{lineCount} lines</span>
              </div>
              <button id="copy-btn" class="text-[12px] text-text-faint hover:text-text-muted transition-colors tracking-wide">
                <span id="copy-text">Copy</span>
              </button>
            </div>

            <div class="p-6 overflow-x-auto">
              <pre class="!bg-transparent !border-0 !p-0 !m-0 !rounded-none"><code class="text-[13px] leading-[1.8] font-mono text-text-muted whitespace-pre-wrap break-words">{rule.content}</code></pre>
            </div>
          </div>
        </div>

        <!-- Source attribution -->
        {rule.sourceUrl && (
          <div class="mt-4 text-[12px] text-text-faint">
            Source: <a href={rule.sourceUrl} target="_blank" rel="noopener" class="hover:text-text-muted transition-colors underline underline-offset-2">{rule.source}</a>
          </div>
        )}

        <!-- Related -->
        {related.length > 0 && (
          <section class="mt-20 pt-12 border-t border-border-subtle">
            <h2 class="text-lg font-medium mb-8 tracking-tight">Related Rules</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-x-6 gap-y-14">
              {related.slice(0, 3).map(r => (
                <RuleCard client:visible rule={r} />
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </div>

  <script define:vars={{ content: rule.content }}>
    function setupCopy(btnId) {
      const btn = document.getElementById(btnId);
      btn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(content);
          if (btnId === 'copy-btn') {
            document.getElementById('copy-text').textContent = 'Copied';
            setTimeout(() => { document.getElementById('copy-text').textContent = 'Copy'; }, 2000);
          } else {
            btn.textContent = 'Copied';
            setTimeout(() => { btn.textContent = 'Copy to Clipboard'; }, 2000);
          }
        } catch {}
      });
    }
    setupCopy('copy-btn');
    setupCopy('copy-btn-sidebar');
  </script>
</Layout>
